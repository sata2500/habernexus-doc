generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(cuid())
  name                 String
  email                String     @unique
  emailVerified        Boolean    @default(false)
  image                String?
  role                 String     @default("USER")
  bio                  String?
  newsletterSubscribed Boolean    @default(true)
  newsletterTime       String     @default("08:00")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  accounts             Account[]
  articles             Article[]
  bookmarks            Bookmark[]
  comments             Comment[]
  media                Media[]
  sessions             Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Article {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  content     String
  excerpt     String?
  coverImage  String?
  status      String         @default("DRAFT")
  viewCount   Int            @default(0)
  authorId    String
  categoryId  String?
  publishedAt DateTime?
  lang        String         @default("tr")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category    Category?      @relation(fields: [categoryId], references: [id])
  bookmarks   Bookmark[]
  comments    Comment[]
  tags        TagOnArticle[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
  @@index([slug])
  @@index([lang])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  icon        String?
  order       Int       @default(0)
  lang        String    @default("tr")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
  personaId   String?
  aiPersona   AiPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
}

model Tag {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  lang      String         @default("tr")
  createdAt DateTime       @default(now())
  articles  TagOnArticle[]
}

model TagOnArticle {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  articleId String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([userId])
  @@index([parentId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model Subscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  isActive         Boolean  @default(true)
  newsletterTime   String   @default("08:00")
  unsubscribeToken String   @unique @default(cuid())
  createdAt        DateTime @default(now())
}

model Media {
  id        String      @id @default(cuid())
  url       String      @unique
  filename  String
  size      Int
  mimeType  String
  status    MediaStatus @default(RAW)
  width     Int?
  height    Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model StaticPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  content     String
  extraData   Json?
  lang        String   @default("tr")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([slug])
}

model SupportTicket {
  id        String           @id @default(cuid())
  subject   String
  userEmail String
  userName  String?
  status    String           @default("OPEN")
  priority  String           @default("NORMAL")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]

  @@index([userEmail])
  @@index([status])
  @@index([createdAt])
}

model SupportMessage {
  id          String        @id @default(cuid())
  ticketId    String
  sender      String
  direction   String
  content     String
  attachments Json?
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

enum MediaStatus {
  RAW
  PROCESSING
  OPTIMIZED
  FAILED
}

/// Yönetici tarafından eklenen RSS kaynakları
model RssFeedSource {
  id            String        @id @default(cuid())
  name          String                              // Örn: "BBC News TR"
  url           String        @unique               // RSS feed URL
  categoryHint  String?                             // Öneri kategori eşleşmesi
  language      String        @default("tr")
  isActive      Boolean       @default(true)
  lastFetchedAt DateTime?
  fetchError    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         RssFeedItem[]

  @@index([isActive])
}

/// RSS'ten çekilen ham haberler
model RssFeedItem {
  id             String        @id @default(cuid())
  sourceId       String
  title          String
  url            String        @unique
  urlHash        String        @unique             // SHA-256 hash, hızlı dedup
  excerpt        String?
  imageUrl       String?
  publishedAt    DateTime?
  status         RssItemStatus @default(PENDING)
  aiScore        Int?                              // 0-100 Gemini öneri puanı
  aiAnalysis     Json?                             // Gemini'nin tam JSON çıktısı
  dismissed      Boolean       @default(false)     // "İlginç değil" işareti
  usedForArticle Boolean       @default(false)     // Bu öneriden haber yazıldıysa
  source         RssFeedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([sourceId])
  @@index([status])
  @@index([aiScore])
  @@index([publishedAt])
  @@index([dismissed])
  @@index([usedForArticle])
}

enum RssItemStatus {
  PENDING   // Henüz AI analizi yapılmadı
  ANALYZED  // Gemini analiz etti, puan verildi
  APPROVED  // Admin onayladı, yazar masasına düştü
  LOW_SCORE // Puan düşük (< 40), gösterilmeyecek
  COVERED   // Zaten haberleştirilmiş konuyla örtüşüyor
  DISMISSED // Yazar/admin "gerek yok" dedi
}

/// Sistem genel ayarları ve aktif QStash Cron görev ID'leri
model SystemSettings {
  id                 String   @id @default("global") // Her zaman tek satır olacak
  rssScanCron        String   @default("0 */2 * * *") // 2 saatte bir
  rssAnalyzeCron     String   @default("0 */4 * * *") // 4 saatte bir
  rssRetentionDays   Int      @default(14)            // Eski öğeler kaç gün saklansın
  qStashScanId       String?  // QStash üzerindeki görev ID'si
  qStashAnalyzeId    String?
  qStashNewsletterId String?  // QStash Newsletter Task ID
  
  // AI Writer Ayarları
  aiWriterModel       String   @default("gemini-2.5-flash")
  aiWriterImageModel  String   @default("gemini-2.5-flash-image")
  aiWriterPrompt      String   @default("Sen profesyonel bir haber editörüsün. Verilen konuyu Google Arama kullanarak araştır ve en güncel, doğru bilgilerle son derece kaliteli, özgün ve tarafsız bir haber makalesi yaz. HTML formatında (h2, p, strong etiketlerini kullanarak) döndür. Başlık dahil etme.")
  aiWriterImagePrompt String   @default("Profesyonel, gerçekçi bir haber fotoğrafı. Fotoğrafçılık kalitesinde, 16:9 oranında, haberin konusuyla ilgili.")
  aiWriterUseRssImage Boolean  @default(true)
  
  // AI Writer Otomasyonu
  aiWriterAutoEnabled Boolean  @default(false)
  aiWriterAutoCount   Int      @default(3)
  aiWriterAutoCron    String   @default("0 */6 * * *") // 6 saatte bir
  qStashAiWriterId    String?  // QStash üzerindeki görev ID'si
  
  updatedAt          DateTime @updatedAt
}

/// AI Yazar Personaları (Farklı kategoriler için farklı yazım ve görsel stilleri)
model AiPersona {
  id          String     @id @default(cuid())
  name        String     @unique // "Spor Editörü", "Ekonomi Uzmanı" vb.
  description String?    
  prompt      String     @db.Text
  imagePrompt String     @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  categories  Category[] // Bir persona birden fazla kategoriye hizmet edebilir
}
